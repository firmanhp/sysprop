---
# clang-tidy configuration for sysprop.
# Only our own source files are linted (see HeaderFilterRegex + lint.sh).
#
# Approach: enable ALL checks (*), then blacklist those incompatible with
# deliberate design decisions. Rationale for each disabled check is below.
#
# Disabled check rationale
# ────────────────────────
# -cppcoreguidelines-pro-bounds-array-to-pointer-decay, -hicpp-no-array-decay:
#   The no-heap design intentionally uses stack char[] buffers passed by pointer
#   throughout (path construction, value reads, typed helpers). Every call site
#   would need NOLINT; the pattern is load-bearing, not a bug.
#
# -cppcoreguidelines-pro-type-vararg, -hicpp-vararg:
#   POSIX syscalls (open(2)) and C stdio (snprintf, fprintf) are unavoidable.
#   Wrapping them in type-safe shims adds complexity with no safety benefit
#   in this controlled internal code.
#
# -modernize-use-trailing-return-type:
#   The codebase uses traditional C-style return-type syntax throughout.
#   Trailing returns would be churn with no correctness benefit.
#
# -readability-identifier-length:
#   Short names (n, rc, fd, s, c) are idiomatic in C/POSIX contexts and within
#   tight one-liner expressions. They are self-evident from context.
#
# -readability-implicit-bool-conversion:
#   Null-pointer checks via if(!ptr) and integer checks via if(rc < 0) are
#   idiomatic C++. Spelling out != nullptr / != 0 everywhere would be verbose.
#
# -cppcoreguidelines-macro-to-enum, -modernize-macro-to-enum:
#   Error codes are #define macros by design so the header stays valid C.
#   enum class is C++-only; a plain C enum would still require casts on the
#   C side, defeating the purpose of the shared header.
#
# -cppcoreguidelines-avoid-c-arrays, -hicpp-avoid-c-arrays, -modernize-avoid-c-arrays:
#   Stack char[] buffers are fundamental to the no-heap design.
#   std::array<char,N> would not reduce risk here and would be more verbose.
#
# -llvmlibc-*, -altera-*, -fuchsia-*, -android-*, -linuxkernel-*:
#   Platform/framework-specific check suites not relevant to this project.
#
# -abseil-*:
#   No Abseil dependency. All abseil-* checks (e.g. abseil-string-find-str-contains)
#   recommend Abseil APIs that are not available in this project.
#
# -llvm-header-guard:
#   The codebase uses #pragma once throughout; the llvm-header-guard check
#   enforces #ifndef-style guards which would be inconsistent and more fragile.

Checks: >-
  *,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -hicpp-no-array-decay,
  -cppcoreguidelines-pro-type-vararg,
  -hicpp-vararg,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-implicit-bool-conversion,
  -cppcoreguidelines-macro-to-enum,
  -modernize-macro-to-enum,
  -cppcoreguidelines-avoid-c-arrays,
  -hicpp-avoid-c-arrays,
  -modernize-avoid-c-arrays,
  -llvmlibc-*,
  -altera-*,
  -fuchsia-*,
  -android-*,
  -linuxkernel-*,
  -abseil-*,
  -llvm-header-guard,

# Treat warnings as errors in CI — remove WarningsAsErrors to allow
# advisory-only runs during development.
WarningsAsErrors: ''

# sysprop.h is the public C API header; C++-specific checks don't apply there.
# Only lint src/ and the C++ internal headers in include/.
HeaderFilterRegex: '.*/sysprop/(src|include/sysprop/(property_store\.h|testing/.*))$'

CheckOptions:
  - key: bugprone-easily-swappable-parameters.MinimumLength
    value: '3'
